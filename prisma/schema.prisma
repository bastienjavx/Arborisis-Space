// Schéma Prisma d'Arborisis.
// Les enums miroir des valeurs de @arborisis/shared/enums — garder synchronisés.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum BuildingType {
  BIOMASS_SYNTHESIZER
  SAP_WELL
  MINERAL_VEIN
  SPORANGE
  PHOTOSYNTHETIC_CANOPY
  STORAGE_VACUOLE
  RESEARCH_NEXUS
  SYMBIOTIC_CORE
  ORBITAL_NURSERY
}

enum ShipType {
  SPORAL_SCOUT
  SYMBIOTIC_HARVESTER
  MYCELIAL_TENDRIL
  CHITIN_FREIGHTER
  BIOLUMINESCENT_CRUISER
  SPOROGENESIS_TITAN
}

enum PlanetType {
  VERDANT
  MINERAL
  SAP_RICH
  SPORE_NEBULA
  BARREN
}

enum ExpeditionPhase {
  OUTBOUND
  RETURNING
  COMPLETED
}

enum ExpeditionOutcome {
  RESOURCE_CACHE
  RARE_SPORES
  DERELICT_SHIP
  INCIDENT
  ANOMALY
  ANCIENT_ARCHIVE
  VOID_ECHO
  CONVERGENCE_BLOOM
}

enum GalacticEventType {
  SPORE_BLOOM
  STELLAR_STORM
  ANCIENT_SIGNAL
  MYCOTOXIN_OUTBREAK
  CONVERGENCE_PULSE
  VOID_RIFT
}

enum AchievementType {
  FIRST_SPROUT
  RESEARCH_PIONEER
  COSMIC_TRAVELER
  COLONIAL_FUNGUS
  FLEET_COMMANDER
  SPORE_MASTER
  ANCIENT_DISCOVERY
  GALACTIC_HIVE
  MASTER_BUILDER
  SCHOLAR
  TITAN_BREEDER
  HUNDRED_SHIPS
  CONVERGENCE_HERALD
  EVENT_SURVIVOR
  DEEP_SPACE
  RESOURCE_BARON
  SPEED_BUILDER
  PEACEFUL_EXPLORER
  SPORAL_SAGE
  THE_CONVERGENCE
}

enum ResearchType {
  ADVANCED_PHOTOSYNTHESIS
  GENETIC_ENGINEERING
  SYMBIOSIS
  TERRAFORMATION
  BIOENGINEERING
  SPORAL_PROPULSION
}

enum JobStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  username         String   @unique
  passwordHash     String
  role             UserRole @default(PLAYER)
  // Hash du refresh token courant (rotation). Null = pas de session active.
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  artifactCount     Int      @default(0)

  planets           Planet[]
  researchLevels    ResearchLevel[]
  researchJobs      ResearchJob[]
  colonizationJobs  ColonizationJob[]
  sessions          Session[]
  expeditions       ExpeditionMission[]
  expeditionReports ExpeditionReport[]
  achievements      PlayerAchievement[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

model Planet {
  id          String     @id @default(uuid())
  name        String
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  isHomeworld Boolean    @default(false)
  planetType  PlanetType @default(VERDANT)

  // Coordonnées galactiques (unicité d'emplacement).
  galaxy   Int
  system   Int
  position Int

  // Stabilité écologique 0..100.
  stability Float @default(100)

  // Stocks de ressources (recalculés serveur depuis lastResourceUpdate).
  biomass  Float @default(0)
  sap      Float @default(0)
  minerals Float @default(0)
  spores   Float @default(0)

  // Horodatage de la dernière accumulation appliquée (anti-triche / calcul lazy).
  lastResourceUpdate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings          PlanetBuilding[]
  constructionJobs   ConstructionJob[]
  colonizationJobs   ColonizationJob[]   @relation("ColonizationSource")
  ships              PlanetShip[]
  shipProductionJobs ShipProductionJob[]
  expeditions        ExpeditionMission[]

  @@unique([galaxy, system, position])
  @@index([ownerId])
  @@map("planets")
}

model PlanetShip {
  id       String   @id @default(uuid())
  planetId String
  planet   Planet   @relation(fields: [planetId], references: [id], onDelete: Cascade)
  type     ShipType
  quantity Int      @default(0)

  @@unique([planetId, type])
  @@map("planet_ships")
}

model ShipProductionJob {
  id         String    @id @default(uuid())
  planetId   String
  planet     Planet    @relation(fields: [planetId], references: [id], onDelete: Cascade)
  shipType   ShipType
  quantity   Int
  status     JobStatus @default(PENDING)
  startedAt  DateTime  @default(now())
  finishesAt DateTime

  @@index([planetId, status])
  @@index([status, finishesAt])
  @@map("ship_production_jobs")
}

model ExpeditionMission {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  planetId       String
  planet         Planet            @relation(fields: [planetId], references: [id], onDelete: Cascade)
  targetGalaxy   Int
  targetSystem   Int
  phase          ExpeditionPhase   @default(OUTBOUND)
  scoutCount     Int
  harvesterCount Int
  tenderilCount  Int               @default(0)
  freighterCount Int               @default(0)
  cruiserCount   Int               @default(0)
  titanCount     Int               @default(0)
  startedAt      DateTime          @default(now())
  arrivesAt      DateTime
  returnsAt      DateTime
  completedAt    DateTime?
  report         ExpeditionReport?

  @@index([userId, phase])
  @@index([phase, arrivesAt])
  @@index([phase, returnsAt])
  @@map("expedition_missions")
}

model ExpeditionReport {
  id               String            @id @default(uuid())
  missionId        String            @unique
  mission          ExpeditionMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  outcome          ExpeditionOutcome
  rulesetVersion   Int
  roll             Int
  rewardBiomass    Float             @default(0)
  rewardSap        Float             @default(0)
  rewardMinerals   Float             @default(0)
  rewardSpores     Float             @default(0)
  lostScouts       Int               @default(0)
  lostHarvesters   Int               @default(0)
  lostTendrils     Int               @default(0)
  lostFreighters   Int               @default(0)
  lostCruisers     Int               @default(0)
  lostTitans       Int               @default(0)
  overflowBiomass  Float             @default(0)
  overflowSap      Float             @default(0)
  overflowMinerals Float             @default(0)
  overflowSpores   Float             @default(0)
  isRead           Boolean           @default(false)
  occurredAt       DateTime          @default(now())
  returnedAt       DateTime?

  @@index([userId, isRead, occurredAt])
  @@map("expedition_reports")
}

model PlanetBuilding {
  id       String       @id @default(uuid())
  planetId String
  planet   Planet       @relation(fields: [planetId], references: [id], onDelete: Cascade)
  type     BuildingType
  level    Int          @default(0)

  @@unique([planetId, type])
  @@map("planet_buildings")
}

model ResearchLevel {
  id     String       @id @default(uuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   ResearchType
  level  Int          @default(0)

  @@unique([userId, type])
  @@map("research_levels")
}

model ConstructionJob {
  id           String       @id @default(uuid())
  planetId     String
  planet       Planet       @relation(fields: [planetId], references: [id], onDelete: Cascade)
  buildingType BuildingType
  targetLevel  Int
  status       JobStatus    @default(PENDING)
  startedAt    DateTime     @default(now())
  finishesAt   DateTime

  @@index([planetId, status])
  @@index([status, finishesAt])
  @@map("construction_jobs")
}

model ResearchJob {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchType ResearchType
  targetLevel  Int
  // Planète hébergeant la recherche (où sont prélevées les ressources).
  planetId     String
  status       JobStatus    @default(PENDING)
  startedAt    DateTime     @default(now())
  finishesAt   DateTime

  @@index([userId, status])
  @@index([status, finishesAt])
  @@map("research_jobs")
}

model GalacticEvent {
  id        String            @id @default(uuid())
  type      GalacticEventType
  startAt   DateTime          @default(now())
  endsAt    DateTime
  processed Boolean           @default(false)

  @@index([endsAt])
  @@map("galactic_events")
}

model PlayerAchievement {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       AchievementType
  unlockedAt DateTime        @default(now())

  @@unique([userId, type])
  @@index([userId])
  @@map("player_achievements")
}

model ColonizationJob {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePlanetId String
  sourcePlanet   Planet    @relation("ColonizationSource", fields: [sourcePlanetId], references: [id], onDelete: Cascade)
  targetGalaxy   Int
  targetSystem   Int
  targetPosition Int
  status         JobStatus @default(PENDING)
  startedAt      DateTime  @default(now())
  finishesAt     DateTime

  @@index([userId, status])
  @@index([status, finishesAt])
  @@map("colonization_jobs")
}
