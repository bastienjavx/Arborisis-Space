// Schéma Prisma d'Arborisis.
// Les enums miroir des valeurs de @arborisis/shared/enums — garder synchronisés.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  MODERATOR
  ADMIN
}

enum ChatScope {
  GLOBAL
  ALLIANCE
  PRIVATE
}

enum ModerationActionType {
  DELETE_MESSAGE
  MUTE
  UNMUTE
  ROLE_CHANGE
}

enum RaceType {
  MYCELIANS
  PHOTOSYNTHEX
  CHITINIDS
}

enum BuildingType {
  BIOMASS_SYNTHESIZER
  SAP_WELL
  MINERAL_VEIN
  SPORANGE
  PHOTOSYNTHETIC_CANOPY
  STORAGE_VACUOLE
  RESEARCH_NEXUS
  SYMBIOTIC_CORE
  ORBITAL_NURSERY
}

enum ShipType {
  SPORAL_SCOUT
  SYMBIOTIC_HARVESTER
  MYCELIAL_TENDRIL
  CHITIN_FREIGHTER
  BIOLUMINESCENT_CRUISER
  SPOROGENESIS_TITAN
  SPORAL_DRONE
  ACID_BOMBER
  CHITIN_DESTROYER
  BIOMASS_DREADNOUGHT
  SEED_POD
  SHADOW_SPORE
  ORBITAL_THORN
  SPORAL_SWARM
  LUMINOUS_WARDEN
  CHITIN_BULWARK
}

enum PlanetType {
  VERDANT
  MINERAL
  SAP_RICH
  SPORE_NEBULA
  BARREN
}

enum PlanetSpecialization {
  PRODUCTION
  MILITARY
  RESEARCH
  FORTRESS
}

enum SeasonStatus {
  ACTIVE
  CLOSED
}

enum SeasonRewardScope {
  PLAYER
  ALLIANCE
}

enum TransferPhase {
  OUTBOUND
  COMPLETED
}

enum ExpeditionPhase {
  OUTBOUND
  RETURNING
  COMPLETED
}

enum NpcEncounterType {
  VOID_RIFT
  MYCOXIN_NEST
  ABANDONED_DERELICT
  FUNGAL_HIVEMIND
  VOID_LEVIATHAN
  CRYSTALLINE_GUARDIAN
  BIOMASS_CORRUPTED
  ANCIENT_SENTINEL
  CHITIN_WARLORD
  SPORAL_PARASITE
  MYCOSPORE_SWARM
}

enum PveMissionPhase {
  TRAVEL
  COMBAT
  RETURNING
  COMPLETED
}

enum PvpMissionType {
  SPY
  ATTACK
}

enum PvpMissionPhase {
  OUTBOUND
  RETURNING
  COMPLETED
}

enum ExpeditionOutcome {
  RESOURCE_CACHE
  RARE_SPORES
  DERELICT_SHIP
  INCIDENT
  ANOMALY
  ANCIENT_ARCHIVE
  VOID_ECHO
  CONVERGENCE_BLOOM
}

enum GalacticEventType {
  SPORE_BLOOM
  STELLAR_STORM
  ANCIENT_SIGNAL
  MYCOTOXIN_OUTBREAK
  CONVERGENCE_PULSE
  VOID_RIFT
}

enum AchievementType {
  FIRST_SPROUT
  RESEARCH_PIONEER
  COSMIC_TRAVELER
  COLONIAL_FUNGUS
  FLEET_COMMANDER
  SPORE_MASTER
  ANCIENT_DISCOVERY
  GALACTIC_HIVE
  MASTER_BUILDER
  SCHOLAR
  TITAN_BREEDER
  HUNDRED_SHIPS
  CONVERGENCE_HERALD
  EVENT_SURVIVOR
  DEEP_SPACE
  RESOURCE_BARON
  SPEED_BUILDER
  PEACEFUL_EXPLORER
  SPORAL_SAGE
  THE_CONVERGENCE
}

enum ResearchType {
  ADVANCED_PHOTOSYNTHESIS
  GENETIC_ENGINEERING
  SYMBIOSIS
  TERRAFORMATION
  BIOENGINEERING
  SPORAL_PROPULSION
  NUTRIENT_CYCLING
  SUBTERRANEAN_ROOTS
  SPORAL_ECONOMY
  CHITIN_ARMOR
  BIOLOGICAL_WARFARE
  SWARM_TACTICS
  ORBITAL_DEFENSE_GRID
  HYPERSPORE_DRIVE
  WORMHOLE_MYCOLOGY
  SPORE_SENSE
  DEEP_SCAN
}

enum JobStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AllianceRole {
  LEADER
  OFFICER
  MEMBER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum UniverseStatus {
  ACTIVE
  PROVISIONING
  CLOSED
  FAILED
}

// ── Économie joueur ──

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemCategory {
  RAW_MATERIAL
  PROCESSED
}

enum MarketOrderSide {
  BUY
  SELL
}

enum MarketOrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum TradeRouteStatus {
  ACTIVE
  PAUSED
  INSUFFICIENT_SHIPS
}

model Universe {
  id             String         @id @default(uuid())
  slug           String         @unique
  name           String
  internalApiUrl String         @unique
  maxPlayers     Int            @default(500)
  playerCount    Int            @default(0)
  status         UniverseStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  users             User[]
  planets           Planet[]
  npcEncounters     NpcEncounter[]
  galacticEvents    GalacticEvent[]
  chatMessages      ChatMessage[]
  moderationActions ModerationAction[]
  seasons           LeaderboardSeason[]
  marketOrders      MarketOrder[]
  marketTrades      MarketTrade[]
  ohlcvCandles      OhlcvCandle[]

  @@map("universes")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         UserRole  @default(PLAYER)
  race         RaceType  @default(MYCELIANS)
  displayName  String?
  bio          String?
  bannerColor  String    @default("#22c55e")
  avatarSeed   String?
  mutedUntil   DateTime?
  universeId   String
  universe     Universe  @relation(fields: [universeId], references: [id], onDelete: Cascade)

  // Hash du refresh token courant (rotation). Null = pas de session active.
  refreshTokenHash String?

  // Vérification email
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?   @unique
  emailVerificationSentAt DateTime?

  // Réinitialisation du mot de passe
  passwordResetToken   String?   @unique
  passwordResetSentAt  DateTime?

  // Double authentification TOTP
  totpSecret  String?
  totpEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifactCount Int @default(0)

  // Récompense quotidienne (rétention)
  lastDailyClaimAt DateTime?
  dailyStreak      Int       @default(0)

  // Résumé « pendant votre absence » : dernière session vue par le joueur.
  lastSeenAt DateTime?

  // Titre cosmétique gagné (saisons de classement, succès…).
  title String?

  planets                   Planet[]
  researchLevels            ResearchLevel[]
  researchJobs              ResearchJob[]
  colonizationJobs          ColonizationJob[]
  sessions                  Session[]
  expeditions               ExpeditionMission[]
  expeditionReports         ExpeditionReport[]
  pveMissions               PveMission[]
  pvpMissions               PvpMission[]
  achievements              PlayerAchievement[]
  quests                    PlayerQuest[]
  seasonRewards             SeasonReward[]
  allianceMembership        AllianceMember?
  leadAlliance              Alliance?
  allianceApplications      AllianceApplication[]
  transferMissions          ResourceTransferMission[]
  sentChatMessages          ChatMessage[]             @relation("ChatAuthor")
  receivedChatMessages      ChatMessage[]             @relation("ChatRecipient")
  deletedChatMessages       ChatMessage[]             @relation("ChatDeletedBy")
  moderationActions         ModerationAction[]        @relation("ModerationActor")
  receivedModerationActions ModerationAction[]        @relation("ModerationTarget")
  accountIpLinks            AccountIpLink[]
  inventorySlots            PlayerInventorySlot[]
  marketOrders              MarketOrder[]
  buyTrades                 MarketTrade[]             @relation("BuyerTrades")
  sellTrades                MarketTrade[]             @relation("SellerTrades")
  craftingJobs              CraftingJob[]
  tradeRoutes               TradeRoute[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

model Planet {
  id          String     @id @default(uuid())
  name        String
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  universeId  String
  universe    Universe   @relation(fields: [universeId], references: [id], onDelete: Cascade)
  isHomeworld Boolean    @default(false)
  planetType  PlanetType @default(VERDANT)

  // Coordonnées galactiques (unicité d'emplacement au sein d'un univers).
  galaxy   Int
  system   Int
  position Int

  // Stabilité écologique 0..100.
  stability           Float @default(100)
  ecologicalStability Float @default(100)

  // Spécialisation planétaire (bonus/malus ciblés).
  specialization PlanetSpecialization?

  // Stocks de ressources (recalculés serveur depuis lastResourceUpdate).
  biomass  Float @default(0)
  sap      Float @default(0)
  minerals Float @default(0)
  spores   Float @default(0)

  // Horodatage de la dernière accumulation appliquée (anti-triche / calcul lazy).
  lastResourceUpdate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings          PlanetBuilding[]
  constructionJobs   ConstructionJob[]
  colonizationJobs   ColonizationJob[]         @relation("ColonizationSource")
  ships              PlanetShip[]
  shipProductionJobs ShipProductionJob[]
  expeditions        ExpeditionMission[]
  pveMissions        PveMission[]
  outgoingPvp        PvpMission[]              @relation("PvpSource")
  incomingPvp        PvpMission[]              @relation("PvpTarget")
  outgoingTransfers  ResourceTransferMission[] @relation("TransferSource")
  incomingTransfers  ResourceTransferMission[] @relation("TransferTarget")
  inventorySlots     PlayerInventorySlot[]
  craftingJobs       CraftingJob[]
  outgoingRoutes     TradeRoute[]              @relation("TradeRouteFrom")
  incomingRoutes     TradeRoute[]              @relation("TradeRouteTo")

  @@unique([universeId, galaxy, system, position])
  @@index([ownerId])
  @@index([universeId])
  @@map("planets")
}

model PlanetShip {
  id       String   @id @default(uuid())
  planetId String
  planet   Planet   @relation(fields: [planetId], references: [id], onDelete: Cascade)
  type     ShipType
  quantity Int      @default(0)

  @@unique([planetId, type])
  @@map("planet_ships")
}

model ShipProductionJob {
  id         String    @id @default(uuid())
  planetId   String
  planet     Planet    @relation(fields: [planetId], references: [id], onDelete: Cascade)
  shipType   ShipType
  quantity   Int
  status     JobStatus @default(PENDING)
  startedAt  DateTime  @default(now())
  finishesAt DateTime

  @@index([planetId, status])
  @@index([status, finishesAt])
  @@map("ship_production_jobs")
}

model ExpeditionMission {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  planetId       String
  planet         Planet            @relation(fields: [planetId], references: [id], onDelete: Cascade)
  targetGalaxy   Int
  targetSystem   Int
  phase          ExpeditionPhase   @default(OUTBOUND)
  scoutCount     Int
  harvesterCount Int
  tenderilCount  Int               @default(0)
  freighterCount Int               @default(0)
  cruiserCount   Int               @default(0)
  titanCount     Int               @default(0)
  startedAt      DateTime          @default(now())
  arrivesAt      DateTime
  returnsAt      DateTime
  completedAt    DateTime?
  report         ExpeditionReport?

  @@index([userId, phase])
  @@index([phase, arrivesAt])
  @@index([phase, returnsAt])
  @@map("expedition_missions")
}

model ExpeditionReport {
  id               String            @id @default(uuid())
  missionId        String            @unique
  mission          ExpeditionMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  outcome          ExpeditionOutcome
  rulesetVersion   Int
  roll             Int
  rewardBiomass    Float             @default(0)
  rewardSap        Float             @default(0)
  rewardMinerals   Float             @default(0)
  rewardSpores     Float             @default(0)
  lostScouts       Int               @default(0)
  lostHarvesters   Int               @default(0)
  lostTendrils     Int               @default(0)
  lostFreighters   Int               @default(0)
  lostCruisers     Int               @default(0)
  lostTitans       Int               @default(0)
  overflowBiomass  Float             @default(0)
  overflowSap      Float             @default(0)
  overflowMinerals Float             @default(0)
  overflowSpores   Float             @default(0)
  isRead           Boolean           @default(false)
  occurredAt       DateTime          @default(now())
  returnedAt       DateTime?

  @@index([userId, isRead, occurredAt])
  @@map("expedition_reports")
}

model PlanetBuilding {
  id                  String       @id @default(uuid())
  planetId            String
  planet              Planet       @relation(fields: [planetId], references: [id], onDelete: Cascade)
  type                BuildingType
  level               Int          @default(0)
  productionIntensity Int          @default(100)

  @@unique([planetId, type])
  @@map("planet_buildings")
}

model ResearchLevel {
  id     String       @id @default(uuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   ResearchType
  level  Int          @default(0)

  @@unique([userId, type])
  @@map("research_levels")
}

model ConstructionJob {
  id           String       @id @default(uuid())
  planetId     String
  planet       Planet       @relation(fields: [planetId], references: [id], onDelete: Cascade)
  buildingType BuildingType
  targetLevel  Int
  status       JobStatus    @default(PENDING)
  startedAt    DateTime     @default(now())
  finishesAt   DateTime

  @@index([planetId, status])
  @@index([status, finishesAt])
  @@map("construction_jobs")
}

model ResearchJob {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchType ResearchType
  targetLevel  Int
  // Planète hébergeant la recherche (où sont prélevées les ressources).
  planetId     String
  status       JobStatus    @default(PENDING)
  startedAt    DateTime     @default(now())
  finishesAt   DateTime

  @@index([userId, status])
  @@index([status, finishesAt])
  @@map("research_jobs")
}

model GalacticEvent {
  id         String            @id @default(uuid())
  universeId String
  universe   Universe          @relation(fields: [universeId], references: [id], onDelete: Cascade)
  type       GalacticEventType
  startAt    DateTime          @default(now())
  endsAt     DateTime
  processed  Boolean           @default(false)

  @@index([endsAt])
  @@index([universeId])
  @@map("galactic_events")
}

model PlayerAchievement {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       AchievementType
  unlockedAt DateTime        @default(now())

  @@unique([userId, type])
  @@index([userId])
  @@map("player_achievements")
}

model PlayerQuest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Id stable de la quête (cf. QUESTS dans shared/constants.ts).
  questId     String
  completedAt DateTime?
  claimedAt   DateTime?

  @@unique([userId, questId])
  @@index([userId])
  @@map("player_quests")
}

model LeaderboardSeason {
  id         String         @id @default(uuid())
  universeId String
  universe   Universe       @relation(fields: [universeId], references: [id], onDelete: Cascade)
  index      Int
  startedAt  DateTime       @default(now())
  endsAt     DateTime
  status     SeasonStatus   @default(ACTIVE)
  rewards    SeasonReward[]

  @@unique([universeId, index])
  @@index([universeId, status])
  @@map("leaderboard_seasons")
}

model SeasonReward {
  id       String            @id @default(uuid())
  seasonId String
  season   LeaderboardSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  scope    SeasonRewardScope
  userId   String
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Alliance concernée pour une récompense d'alliance (null pour le classement individuel).
  allianceId String?
  rank       Int
  score      Int
  title      String?
  rewardBiomass  Float @default(0)
  rewardSap      Float @default(0)
  rewardMinerals Float @default(0)
  rewardSpores   Float @default(0)
  claimedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, claimedAt])
  @@index([seasonId])
  @@unique([seasonId, scope, userId])
  @@map("season_rewards")
}

model ColonizationJob {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePlanetId String
  sourcePlanet   Planet    @relation("ColonizationSource", fields: [sourcePlanetId], references: [id], onDelete: Cascade)
  targetGalaxy   Int
  targetSystem   Int
  targetPosition Int
  status         JobStatus @default(PENDING)
  startedAt      DateTime  @default(now())
  finishesAt     DateTime

  @@index([userId, status])
  @@index([status, finishesAt])
  @@map("colonization_jobs")
}

model Alliance {
  id          String   @id @default(uuid())
  tag         String   @unique @db.VarChar(4)
  name        String   @db.VarChar(40)
  description String?  @db.VarChar(500)
  bannerColor String   @default("#22c55e") @db.VarChar(7)
  leaderId    String   @unique
  leader      User     @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      AllianceMember[]
  applications AllianceApplication[]
  chatMessages ChatMessage[]

  @@map("alliances")
}

model ChatMessage {
  id          String    @id @default(uuid())
  universeId  String
  universe    Universe  @relation(fields: [universeId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation("ChatAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  scope       ChatScope
  allianceId  String?
  alliance    Alliance? @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?     @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  content     String    @db.VarChar(1000)
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("ChatDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  moderationActions ModerationAction[]

  @@index([universeId, scope, createdAt])
  @@index([allianceId, createdAt])
  @@index([authorId, recipientId, createdAt])
  @@map("chat_messages")
}

model ModerationAction {
  id           String               @id @default(uuid())
  universeId   String
  universe     Universe             @relation(fields: [universeId], references: [id], onDelete: Cascade)
  moderatorId  String
  moderator    User                 @relation("ModerationActor", fields: [moderatorId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?                @relation("ModerationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  messageId    String?
  message      ChatMessage?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  action       ModerationActionType
  reason       String?              @db.VarChar(500)
  createdAt    DateTime             @default(now())

  @@index([universeId, createdAt])
  @@index([moderatorId, createdAt])
  @@map("moderation_actions")
}

model AllianceMember {
  id         String       @id @default(uuid())
  allianceId String
  alliance   Alliance     @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String       @unique
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       AllianceRole @default(MEMBER)
  joinedAt   DateTime     @default(now())

  @@index([allianceId])
  @@map("alliance_members")
}

model AllianceApplication {
  id         String            @id @default(uuid())
  allianceId String
  alliance   Alliance          @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  message    String?           @db.VarChar(500)
  status     ApplicationStatus @default(PENDING)
  createdAt  DateTime          @default(now())

  @@unique([allianceId, userId])
  @@index([allianceId, status])
  @@map("alliance_applications")
}

model NpcEncounter {
  id          String           @id @default(uuid())
  universeId  String
  universe    Universe         @relation(fields: [universeId], references: [id], onDelete: Cascade)
  type        NpcEncounterType
  galaxy      Int
  system      Int
  position    Int
  difficulty  Int              @default(1)
  health      Int              @default(100)
  maxHealth   Int              @default(100)
  rewards     Json             @default("{}")
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  pveMissions PveMission[]

  @@unique([universeId, galaxy, system, position])
  @@index([expiresAt])
  @@index([universeId])
  @@map("npc_encounters")
}

model PveMission {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  encounterId     String
  encounter       NpcEncounter    @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  sourcePlanetId  String
  sourcePlanet    Planet          @relation(fields: [sourcePlanetId], references: [id], onDelete: Cascade)
  phase           PveMissionPhase @default(TRAVEL)
  ships           Json
  travelArrivesAt DateTime
  combatEndsAt    DateTime
  returnsAt       DateTime
  result          Json?
  createdAt       DateTime        @default(now())
  completedAt     DateTime?

  @@index([userId, phase])
  @@index([encounterId])
  @@map("pve_missions")
}

model PvpMission {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           PvpMissionType
  sourcePlanetId String
  sourcePlanet   Planet          @relation("PvpSource", fields: [sourcePlanetId], references: [id], onDelete: Cascade)
  targetPlanetId String
  targetPlanet   Planet          @relation("PvpTarget", fields: [targetPlanetId], references: [id], onDelete: Cascade)
  phase          PvpMissionPhase @default(OUTBOUND)
  ships          Json // Record<ShipType, number>
  arrivesAt      DateTime
  returnsAt      DateTime
  result         Json? // { outcome: 'SUCCESS'|'FAILURE'|'DRAW', loot?: {...}, lostShips: {... }, defenderLosses?: {... }, report?: {... } }
  completedAt    DateTime?
  createdAt      DateTime        @default(now())

  @@index([userId, phase])
  @@index([targetPlanetId, phase])
  @@map("pvp_missions")
}

model ResourceTransferMission {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePlanetId String
  sourcePlanet   Planet        @relation("TransferSource", fields: [sourcePlanetId], references: [id], onDelete: Cascade)
  targetPlanetId String
  targetPlanet   Planet        @relation("TransferTarget", fields: [targetPlanetId], references: [id], onDelete: Cascade)
  ships          Json
  resources      Json
  phase          TransferPhase @default(OUTBOUND)
  arrivesAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([userId, phase])
  @@index([phase, arrivesAt])
  @@map("resource_transfer_missions")
}

/// Journal d'audit anti-triche : trace les anomalies détectées (invariants de
/// ressources violés, niveaux impossibles, jobs trop rapides, comptes liés,
/// dépassements de cadence). Volontairement découplé du gameplay : on n'y écrit
/// jamais de manière bloquante et le modèle n'est pas scopé par univers (cf.
/// SCOPED_MODELS) — `universeId` est stocké explicitement pour l'analyse.
model AntiCheatEvent {
  id         String   @id @default(uuid())
  userId     String?
  universeId String?
  /// Catégorie d'anomalie (string libre interne, non exposée au client).
  type       String
  /// INFO | WARN | CRITICAL
  severity   String   @default("WARN")
  detail     Json
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([universeId, severity, createdAt])
  @@map("anti_cheat_events")
}

/// Lien compte ↔ empreinte IP (hachée) pour la détection de multi-comptes.
/// Un même `ipHash` rattaché à plusieurs `userId` dans le même univers est un
/// signal de comptes liés / push. L'IP n'est jamais stockée en clair.
model AccountIpLink {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipHash      String
  universeId  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([userId, ipHash])
  @@index([ipHash])
  @@map("account_ip_links")
}

// ═══════════════════════════════════════════════════════════════════
// Économie joueur : inventaire, marché, artisanat, routes
// ═══════════════════════════════════════════════════════════════════

/// Inventaire d'un joueur sur une planète. Un slot par (userId, planetId, itemKey).
model PlayerInventorySlot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planetId  String
  planet    Planet   @relation(fields: [planetId], references: [id], onDelete: Cascade)
  itemKey   String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, planetId, itemKey])
  @@index([userId])
  @@index([planetId])
  @@map("player_inventory_slots")
}

/// Ordre de marché (achat ou vente d'un objet à un prix limite).
model MarketOrder {
  id             String            @id @default(uuid())
  universeId     String
  universe       Universe          @relation(fields: [universeId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Clé stable de l'objet (ItemKey).
  itemKey        String
  side           MarketOrderSide
  status         MarketOrderStatus @default(OPEN)
  pricePerUnit   Int
  quantity       Int
  filledQuantity Int               @default(0)
  /// Biomasse mise en séquestre pour les ordres d'achat (libérée si annulé/rempli).
  escrowBiomass  Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  expiresAt      DateTime?
  sourcePlanetId String

  buyTrades  MarketTrade[] @relation("OrderBuy")
  sellTrades MarketTrade[] @relation("OrderSell")

  @@index([universeId, itemKey, side, status, pricePerUnit])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("market_orders")
}

/// Transaction exécutée entre deux ordres de marché (maker-taker).
model MarketTrade {
  id          String   @id @default(uuid())
  universeId  String
  universe    Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)
  itemKey     String
  buyOrderId  String
  buyOrder    MarketOrder @relation("OrderBuy", fields: [buyOrderId], references: [id])
  sellOrderId String
  sellOrder   MarketOrder @relation("OrderSell", fields: [sellOrderId], references: [id])
  buyerId     String
  buyer       User        @relation("BuyerTrades", fields: [buyerId], references: [id])
  sellerId    String
  seller      User        @relation("SellerTrades", fields: [sellerId], references: [id])
  price       Int
  quantity    Int
  executedAt  DateTime    @default(now())
  buyerPlanetId  String
  sellerPlanetId String

  @@index([universeId, itemKey, executedAt])
  @@index([buyerId, executedAt])
  @@index([sellerId, executedAt])
  @@map("market_trades")
}

/// Bougie OHLCV pour les graphiques de cours (1h / 4h / 1d).
model OhlcvCandle {
  id         String   @id @default(uuid())
  universeId String
  universe   Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)
  itemKey    String
  interval   String
  openTime   DateTime
  open       Int
  high       Int
  low        Int
  close      Int
  volume     Int      @default(0)

  @@unique([universeId, itemKey, interval, openTime])
  @@index([universeId, itemKey, interval, openTime])
  @@map("ohlcv_candles")
}

/// Job d'artisanat : transforme des matières premières en objets.
model CraftingJob {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planetId    String
  planet      Planet   @relation(fields: [planetId], references: [id], onDelete: Cascade)
  recipeId    String
  outputKey   String
  outputQty   Int
  quantity    Int      @default(1)
  status      String   @default("PENDING")
  startedAt   DateTime @default(now())
  completesAt DateTime

  @@index([userId, status])
  @@index([planetId, status])
  @@index([status, completesAt])
  @@map("crafting_jobs")
}

/// Route commerciale automatisée entre deux planètes du même joueur.
model TradeRoute {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromPlanetId   String
  fromPlanet     Planet           @relation("TradeRouteFrom", fields: [fromPlanetId], references: [id], onDelete: Cascade)
  toPlanetId     String
  toPlanet       Planet           @relation("TradeRouteTo", fields: [toPlanetId], references: [id], onDelete: Cascade)
  /// Clé de l'objet (null si c'est une ressource de base).
  itemKey        String?
  /// Ressource de base (null si c'est un objet).
  resource       String?
  quantityPerRun Int
  shipType       String
  shipCount      Int
  intervalHours  Int              @default(4)
  status         TradeRouteStatus @default(ACTIVE)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([status, nextRunAt])
  @@map("trade_routes")
}
