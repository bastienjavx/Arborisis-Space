# ─────────────────────────────────────────────────────────────
# Arborisis — variables d'environnement (exemple)
# Copier en `.env` et renseigner. NE JAMAIS commiter de vrais secrets.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Base de données (PostgreSQL) ──
# Local via docker-compose : user/password/db = arborisis
DATABASE_URL=postgresql://arborisis:arborisis@localhost:5432/arborisis?schema=public

# ── Redis (BullMQ) ──
REDIS_URL=redis://localhost:6379

# ── API (NestJS) ──
API_PORT=4000
API_ORIGIN=http://localhost:4000
# Origine autorisée par CORS (front)
WEB_ORIGIN=http://localhost:3000
# Domaine des cookies (laisser vide en local)
COOKIE_DOMAIN=

# ── Auto-provisioning Railway ──
# Token Railway API v2 (https://railway.app/account/tokens)
RAILWAY_API_TOKEN=
# ID du projet Railway (disponible dans l'URL du dashboard)
RAILWAY_PROJECT_ID=
# ID du service API principal à dupliquer pour chaque univers
RAILWAY_SERVICE_TEMPLATE_ID=
# ID de l'environnement Railway (optionnel)
RAILWAY_ENVIRONMENT_ID=
# Activer la création automatique d'univers ('true' en production)
UNIVERSE_PROVISIONING_ENABLED=false
# Joueurs max par univers (au-delà, un nouveau node est provisionné)
UNIVERSE_MAX_PLAYERS=500
# Fraction de remplissage déclenchant le pré-provisioning d'un node (0.9 = 90 %)
UNIVERSE_PROVISION_THRESHOLD=0.9
# Réplicas du service API de chaque node provisionné
UNIVERSE_PROVISION_REPLICAS=2
# Délai max (ms) d'attente que le node provisionné soit sain avant de l'activer
RAILWAY_DEPLOY_TIMEOUT_MS=180000

# ── Auth / JWT ──
# Générer des secrets forts : `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-please
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-please
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
# Chiffrement au repos des secrets TOTP (2FA). Optionnel mais recommandé en prod.
TOTP_ENC_KEY=change-me-totp-encryption-key-min-32-chars

# ── Web (Next.js) ──
WEB_PORT=3000
# URL publique canonique, sans slash final (requise en production pour le SEO).
SITE_URL=https://arborisis.com
# Jeton de validation Google Search Console (contenu uniquement, sans balise HTML).
GOOGLE_SITE_VERIFICATION=
# URL serveur-à-serveur utilisée par le proxy Next.js `/api`.
API_INTERNAL_URL=http://localhost:4000
# Secret de signature du cookie d'univers (HMAC-SHA256).
UNIVERSE_COOKIE_SECRET=change-me-universe-cookie-secret-min-32-chars
