{
  "projectId": "6bbe25cf-72b5-4afd-886a-053110d86e8b",
  "pkg": "@arborisis/web",
  "globalName": "arborisis",
  "shape": "package",
  "srcDir": "src/components",
  "tsconfig": "tsconfig.json",
  "cssEntry": "ds-built.css",
  "componentSrcMap": {
    "AnimatedButton": "src/components/AnimatedButton.tsx",
    "AnimatedCard": "src/components/AnimatedCard.tsx",
    "AnimatedCountdown": "src/components/AnimatedCountdown.tsx",
    "AnimatedCounter": "src/components/AnimatedCounter.tsx",
    "Countdown": "src/components/Countdown.tsx",
    "EventBanner": "src/components/EventBanner.tsx",
    "GlowText": "src/components/GlowText.tsx",
    "HoverGlowCard": "src/components/HoverGlowCard.tsx",
    "LoadingScreen": "src/components/LoadingScreen.tsx",
    "PageHeader": "src/components/PageHeader.tsx",
    "ParticleBackground": "src/components/ParticleBackground.tsx",
    "ParticleField": "src/components/ParticleField.tsx",
    "QuantityControl": "src/components/QuantityControl.tsx",
    "ResourceBar": "src/components/ResourceBar.tsx",
    "ResourceCost": "src/components/ResourceCost.tsx",
    "StaggerContainer": "src/components/StaggerContainer.tsx",
    "StaggerItem": "src/components/StaggerContainer.tsx",
    "StatCard": "src/components/StatCard.tsx"
  },
  "runtimeFontPrefixes": ["Inter"],
  "buildCmd": "cd apps/web && npx tailwindcss -i src/app/globals.css -o ds-built.css --content 'src/**/*.{ts,tsx}' && cd ../.. && node .ds-sync/package-build.mjs --config .design-sync/config.json --node-modules node_modules --entry apps/web/src/components/ds-index.ts --out ./ds-bundle"
}
